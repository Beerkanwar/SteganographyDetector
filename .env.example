# ==========================
# BACKEND ENVIRONMENT VARS
# ==========================
BACKEND_PORT=8000
API_V1_STR=/api/v1
# Generate a secure 32-byte base64 encoded string for SECRET_KEY in production
SECRET_KEY=change_this_to_a_secure_random_string_for_production
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ==========================
# FRONTEND ENVIRONMENT VARS
# ==========================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ==========================
# ML ENVIRONMENT VARS
# ==========================
DATASET_PATH=./datasets/coco2017
BATCH_SIZE=32
LEARNING_RATE=1e-4
NUM_EPOCHS=50
